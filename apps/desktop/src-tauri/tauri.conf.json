{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Werkstatt Motion",
  "version": "1.0.0",
  "identifier": "de.werkstattmotion.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev:vite",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build:vite",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Werkstatt Motion",
        "width": 1280,
        "height": 800,
        "minWidth": 1100,
        "minHeight": 700,
        "dragDropEnabled": false,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "license": "MIT",
    "licenseFile": "../../../LICENSE",
    "targets": ["deb"],
    "publisher": "Werkstatt Motion",
    "copyright": "© 2026 Werkstatt Motion",
    "category": "Utility",
    "shortDescription": "Fahrzeuge, Prioritäten und offene Zahlungen für die Werkstatt",
    "longDescription": "Werkstatt Motion ist eine lokale Desktop-App für kleine Werkstätten: eine Hauptansicht mit Fahrzeugliste, Priorisierung per Drag-and-drop, offenen Zahlungen, Backup und Wiederherstellung – vollständig offline, ohne Konto und ohne Internetverbindung.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico",
        "languages": ["German"],
        "displayLanguageSelector": false
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDk4RDM0MDYzNzUwOUEzRjEKUldUeG93bDFZMERUbUkrS0NKSDNwQkdnWmNPd2xrbHFOcld3aXcrMk5OTTd5YlduMWxMazExY2MK",
      "endpoints": [
        "https://github.com/Oko-Tester/Werkstatt-Motion/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
